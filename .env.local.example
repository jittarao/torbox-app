# ============================================
# Next.js Application Environment Variables
# ============================================
# Copy this file to .env.local in the root directory for LOCAL DEVELOPMENT
# Note: Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# This file is for LOCAL FRONTEND DEVELOPMENT only

# ============================================
# Backend Integration (Required if using backend)
# ============================================
# Backend URL for API calls (used when backend is enabled)
# Default: http://localhost:3001 (for local development)
BACKEND_URL=http://localhost:3001

# Optional: must match backend when set (≥16 chars). Omit for legacy installs.
# BACKEND_SERVICE_SECRET=generate_with_openssl_rand_base64_32

# Disable backend integration (set to 'true' to disable)
# When disabled, the app will use browser localStorage only
BACKEND_DISABLED=false

# Hide the dedicated search page and nav link (self-host opt-out)
# SEARCH_PAGE_DISABLED=false

# ============================================
# Download list sync (Optional — frontend only)
# ============================================
# Server-side cache for /api/torrents, /api/usenet, /api/webdl (Next.js process).
# See DEPLOYMENT.md#download-list-sync
# DOWNLOAD_SYNC_CACHE_TTL_MS=1800000
# DOWNLOAD_SYNC_RECONCILE_INTERVAL_MS=300000
# DOWNLOAD_SYNC_RECONCILE_JITTER_MS=60000
# DOWNLOAD_SYNC_SHALLOW_FRESHNESS_MS=10000

# ============================================
# Application Configuration
# ============================================
# Public application URL (used for OAuth callbacks and redirects)
# Default: http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Optional Configuration
# ============================================
# Set to skip @t3-oss/env-nextjs validation (e.g. one-off scripts)
# SKIP_ENV_VALIDATION=true

# Application version (optional; default comes from package.json at build time)
# NEXT_PUBLIC_TORBOX_MANAGER_VERSION=0.1.9

# TorBox referral code for links and "Apply to my account" (your user_referral UUID from torbox.app/subscription)
# NEXT_PUBLIC_TORBOX_REFERRAL_CODE=your-uuid-here

# ============================================
# Analytics & Monitoring (Optional)
# ============================================
# PostHog Analytics - Optional
# Get your key from https://posthog.com
# Uncomment and configure to enable PostHog analytics
# NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Rybbit (https://rybbit.com/docs/script) — optional, server-side env (works at container runtime)
# When set, PostHog init is skipped. Use first-party proxy path unless RYBBIT_SCRIPT_SRC is set.
# RYBBIT_SITE_ID=your_site_id
# RYBBIT_SCRIPT_SRC=https://your-rybbit-host.example/api/script.js

# Sentry Error Tracking - Optional
# DSN is currently hardcoded in sentry config files
# To make it configurable, you would need to update sentry.*.config.ts files
# Uncomment to configure Sentry DSN via environment variable
# SENTRY_DSN=your_sentry_dsn_here

# ============================================
# Development & Build
# ============================================
# Node environment: development, production, or test
NODE_ENV=development

# Disable Next.js telemetry (recommended)
NEXT_TELEMETRY_DISABLED=1

# Enable bundle analyzer - Optional
# Uncomment and set to 'true' to analyze bundle size during build
# ANALYZE=false

# ============================================
# Notes
# ============================================
# - Variables starting with NEXT_PUBLIC_ are exposed to the browser
# - Never commit .env.local to version control
# - For local development, also set up backend/.env (see backend/.env.example)
# - BACKEND_URL should match your local backend server URL (default: http://localhost:3001)
# - For Docker Compose deployment, use .env.example in root directory instead
# - Optional variables are commented out - uncomment to enable them
