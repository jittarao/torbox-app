# ============================================
# Express.js Backend Environment Variables
# ============================================
# Copy this file to .env in the backend directory for LOCAL DEVELOPMENT
# This file is for LOCAL BACKEND DEVELOPMENT only
# For Docker Compose deployment, use .env.example in the root directory instead

# ============================================
# Server Configuration (Required)
# ============================================
# Backend server port
# Default: 3001
PORT=3001

# Node environment: development, production, or test
NODE_ENV=development

# ============================================
# CORS Configuration (Required)
# ============================================
# Frontend URL(s) for CORS (comma-separated for multiple origins)
# Default: http://localhost:3000
# Example for multiple: http://localhost:3000,https://app.example.com
FRONTEND_URL=http://localhost:3000

# ============================================
# TorBox API Client Configuration (Optional)
# ============================================
# TorBox API base URL - Optional
# Uncomment to override the default API base URL
# TORBOX_API_BASE=https://api.torbox.app

# TorBox API version - Optional
# Uncomment to override the default API version
# TORBOX_API_VERSION=v1

# ============================================
# Security (Required in Production)
# ============================================
# Encryption key for sensitive data (REQUIRED in production)
# Generate a secure random key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: Changing this key will make encrypted data unreadable!
# WARNING: Keep this key secure and never commit it to version control!
ENCRYPTION_KEY=your_secure_encryption_key_here_minimum_32_characters

# Optional: shared secret for Next.js → backend internal routes (api-key registration, status).
# When set, must match frontend .env.local. When unset, internal routes stay open (legacy behavior).
# BACKEND_SERVICE_SECRET=generate_with_openssl_rand_base64_32

# Salt for key derivation (optional but recommended in production)
# Set a unique value per installation so two deployments with the same ENCRYPTION_KEY don't share derived keys.
# If unset, a default is used and a warning is logged.
# ENCRYPTION_SALT=your_unique_salt_per_installation

# ============================================
# Database Configuration (Optional)
# ============================================
# Master database path (stores user registry and API keys)
# API keys are stored in the master database via API, not as environment variables
# Default: {cwd}/data/master.db (backend/data when running locally, /app/data in Docker)
# Uncomment to override the default path
# MASTER_DB_PATH=./data/master.db

# User database directory (where per-user databases are stored)
# Default: {cwd}/data/users
# Uncomment to override the default directory
# USER_DB_DIR=./data/users

# Maximum database connections in pool - Optional
# Default: 50 (sized for concurrent polls + sync + API; connections are closed after each poll/sync)
# Increase only if you see pool warnings with many concurrent API users; avoid keeping 100s of idle connections.
# Pool statistics are available via /api/health/detailed endpoint.
# Uncomment to override
# MAX_DB_CONNECTIONS=50

# Per-user poll timeout (ms) - Optional
# Default: 180000 (3 min). Increase if users with many torrents hit "Per-user poll timeout" in logs.
# Lower (e.g. 120000) to free concurrency slots faster when under heavy load.
# POLL_KICKOUT_MS=180000

# TorBox API outage handling (automation pause / recovery probes via /api/user/me)
# TORBOX_OUTAGE_CYCLES_BEFORE_PAUSE=2
# TORBOX_MIN_PAUSE_MS=120000
# TORBOX_OUTAGE_RECOVERY_INTERVAL_MS=180000
# TORBOX_RECOVERY_PROBE_TIMEOUT_MS=10000
# TORBOX_PROBE_MAX_KEY_ATTEMPTS=3
# TORBOX_RECENT_SUCCESS_MEMORY_SIZE=8

# Full-sync concurrency during RefreshPollers - Optional
# Default: 5. Lower = fewer DB connections used during full sync; higher = faster sync, more pool pressure.
# REFRESH_SYNC_CONCURRENCY=5

# ============================================
# Optional: require x-api-key on all user API routes (default allows legacy authId query param)
# BACKEND_REQUIRE_API_KEY=false

# Optional: admin API key for /api/admin (if unset, admin routes return 503)
# ADMIN_API_KEY=generate_with_openssl_rand_base64_32

# Rate limiting (Optional)
# ============================================
# IP_RATE_LIMIT_MAX=1000
# USER_RATE_LIMIT_MAX=500
# TRUST_PROXY=true

# ============================================
# Development/Testing Configuration (Development Only)
# ============================================
# Interval multiplier for faster testing in development
# Reduces all automation rule intervals and polling intervals for faster testing
# Default: 0.1 (10x faster - 5 minutes becomes 30 seconds)
# Examples:
#   DEV_INTERVAL_MULTIPLIER=0.1  # 10x faster (5min -> 30sec, 60min -> 6min)
#   DEV_INTERVAL_MULTIPLIER=0.01 # 100x faster (5min -> 3sec, 60min -> 36sec)
#   DEV_INTERVAL_MULTIPLIER=1.0  # Normal speed (no change)
# WARNING: Only works when NODE_ENV=development
# WARNING: Minimum interval is enforced (0.1 minutes = 6 seconds minimum in dev)
# Uncomment to override the default multiplier
# DEV_INTERVAL_MULTIPLIER=0.1

# ============================================
# Notes
# ============================================
# - This file is for LOCAL DEVELOPMENT only
# - For Docker Compose deployment, use .env.example in the root directory
# - Never commit .env to version control
# - ENCRYPTION_KEY is critical - generate a secure random key
# - For local development, relative paths like ./data/master.db work fine
# - API keys are stored in the master database via API (multi-user architecture)
# - FRONTEND_URL can accept multiple origins separated by commas
# - Make sure the data directory exists and is writable
# - Optional variables are commented out - uncomment to enable/configure them